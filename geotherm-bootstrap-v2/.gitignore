# =============================================================================
# Geotherm – .gitignore (Next.js 15 + TypeScript + Supabase)
# =============================================================================

# -----------------------------------------------------------------------------
# Node / Next.js – Build-Artefakte und Abhaengigkeiten
# -----------------------------------------------------------------------------
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Env-Files – niemals Secrets committen, aber Beispiel-Datei behalten
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# -----------------------------------------------------------------------------
# Logs – alle Varianten von npm/yarn/pnpm und generische Log-Files
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# -----------------------------------------------------------------------------
# Testing – Coverage, Playwright, Jest
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/

# -----------------------------------------------------------------------------
# IDE & Editor – VSCode/JetBrains/Vim, aber geteilte Settings behalten
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# Betriebssystem – macOS/Windows-Muell
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Deployment – Vercel, Turbo-Cache
# -----------------------------------------------------------------------------
.vercel
.turbo

# -----------------------------------------------------------------------------
# Claude Code – Session-/Projekt-State ignorieren, aber hooks/ committen
# -----------------------------------------------------------------------------
.claude/projects/
.claude/shell-snapshots/
.claude/todos/
.claude/backups/
.claude/session-env/
.claude/settings.local.json

# -----------------------------------------------------------------------------
# Supabase – temporaere Dateien der CLI
# -----------------------------------------------------------------------------
supabase/.temp/
supabase/.branches/

# -----------------------------------------------------------------------------
# Sonstiges – Zertifikate, Keys
# -----------------------------------------------------------------------------
*.pem
